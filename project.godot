; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godot Game Template"
run/main_scene="res://menu_screens/language_selection/language_selection.tscn"
config/features=PackedStringArray("4.2", "Mobile")
boot_splash/bg_color=Color(0.141176, 0.141176, 0.141176, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"
run/main_scene.release="res://menu_screens/language_selection/language_selection.tscn"

[autoload]

InputHandler="*res://autoloads/input_handler/input_handler.tscn"
Settings="*res://autoloads/settings.gd"
GameOverScreen="*res://autoloads/game_over_screen/game_over_screen.tscn"
PauseMenu="*res://autoloads/pause_menu/pause_menu.tscn"
Notifications="*res://autoloads/notifications/notifications.tscn"
Transitions="*res://autoloads/transitions/transitions.tscn"
SceneSwitcher="*res://autoloads/scene_switcher.gd"
SoundManager="*res://autoloads/sound_manager.gd"
Utils="*res://autoloads/utils.gd"
WorldEnv="*res://autoloads/world_environment.tscn"
NewSettings="*res://autoloads/new_settings.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/initial_position_type=3
window/size/resizable=false
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://autoloads/": "orange",
"res://game/": "green",
"res://menu_screens/": "teal",
"res://prefabs/": "red",
"res://themes/": "purple"
}

[gui]

theme/custom="res://themes/default_theme.tres"

